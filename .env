# Vite build-time env vars (VITE_-prefixed vars are inlined into the client
# bundle at build time). See wrangler.toml for the server-side counterpart.

# Set to "true" to run the pattern learner / typing assistant silently —
# suggestions are computed and logged to the console but never shown to the
# doctor — during the initial validation period (recommended: 20-30 real
# dictation sessions in shadow mode before trusting suggestions live).
VITE_SHADOW_MODE=false
